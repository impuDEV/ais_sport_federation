{
	"compilerOptions": {
		"rootDir": ".",
		"outDir": "./dist/",
		"noImplicitAny": true,
		"module": "ESNext",
		"jsx": "react-jsx",
		"allowJs": true,
		"paths": {
			"@/*": ["./src/*"]
		},
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"sourceMap": true,
		"resolveJsonModule": true,
		"isolatedModules": false,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true
	},
	"ts-node": {
		"compilerOptions": {
			"module": "CommonJS"
		}
	},
	"include": [
		"./src/**/*.ts",
		"./src/**/*.tsx"
	]
}
